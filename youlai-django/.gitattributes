# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Python files
*.py text eol=lf
*.ipynb text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Requirements
requirements*.txt text eol=lf

# Documentation
*.md text eol=lf
*.rst text eol=lf

# Shell scripts
*.sh text eol=lf

# Docker
Dockerfile text eol=lf
docker-compose*.yml text eol=lf
