# Django 本地环境变量配置
# 请勿将此文件提交到版本控制系统 (.gitignore 已忽略)

# ================================
# Django 核心配置
# ================================

# DJANGO_SETTINGS_MODULE: Django 配置入口（默认开发环境）
# - 开发：config.settings.dev
# - 生产：config.settings.prod（部署时建议用系统环境变量注入，不依赖此文件）
DJANGO_SETTINGS_MODULE=config.settings.dev

# DJANGO_SECRET_KEY: Django 密钥（用于签名，生产环境务必修改且保密）
DJANGO_SECRET_KEY=django-insecure-dev-key-change-in-production

# ================================
# 数据库配置
# ================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=youlai_admin_django
DB_USER=root
DB_PASSWORD=root

# ================================
# Redis 配置
# ================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_DB=12

# ================================
# JWT 配置
# ================================
JWT_ACCESS_TOKEN_LIFETIME=7200
JWT_REFRESH_TOKEN_LIFETIME=604800
JWT_SECRET_KEY=SecretKey012345678901234567890123456789012345678901234567890123456789

# ================================
# 邮件配置
# ================================
EMAIL_HOST=smtp.youlai.tech
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=123456

# ================================
# MinIO 配置
# ================================
MINIO_HOST_PORT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=public
MINIO_SSL=false
MINIO_SAVE_FILE_PREFIX_DOMAIN=true

# MinIO
MINIO_CUSTOM_DOMAIN=https://www.youlai.tech/storage

# ================================
# 缓存配置
# ================================
CACHE_ENABLED=false
CACHE_TYPE=redis
CACHE_TTL_MS=3600000
CACHE_NULL_VALUES=true

# ================================
# 文件存储配置 (OSS)
# ================================
OSS_TYPE=minio

# MinIO
MINIO_CUSTOM_DOMAIN=https://www.youlai.tech/storage

# 阿里云 OSS
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET_NAME=default

# 本地存储
LOCAL_STORAGE_PATH=

# ================================
# 短信配置
# ================================
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_DOMAIN=dysmsapi.aliyuncs.com
ALIYUN_SMS_REGION_ID=cn-shanghai
ALIYUN_SMS_SIGN_NAME=
SMS_REGISTER_TEMPLATE=
SMS_LOGIN_TEMPLATE=
SMS_CHANGE_MOBILE_TEMPLATE=
MOBILE_CODE_LENGTH=6
MOBILE_CODE_TIMEOUT=300

# ================================
# 会话/安全配置
# ================================
SESSION_TYPE=jwt
REDIS_TOKEN_ALLOW_MULTI_LOGIN=true

# ================================
# 验证码配置
# ================================
CAPTCHA_TYPE=circle
CAPTCHA_WIDTH=140
CAPTCHA_HEIGHT=44
CAPTCHA_INTERFERE_COUNT=1
CAPTCHA_TEXT_ALPHA=1.0
CAPTCHA_CODE_TYPE=math
CAPTCHA_CODE_LENGTH=4
CAPTCHA_FONT_NAME=SansSerif
CAPTCHA_FONT_WEIGHT=1
CAPTCHA_FONT_SIZE=28
CAPTCHA_EXPIRE_SECONDS=120

# ================================
# 微信小程序配置
# ================================
WX_MINIAPP_APP_ID=Your_AppId
WX_MINIAPP_APP_SECRET=Your_AppSecret

# ================================
# XXL-Job 定时任务配置 (开发环境)
# ================================
XXL_JOB_ENABLED=false
XXL_JOB_ADMIN_ADDRESSES=http://127.0.0.1:8686/xxl-job-admin
XXL_JOB_ACCESS_TOKEN=default_token
XXL_JOB_EXECUTOR_APP_NAME=xxl-job-executor-youlai-django
XXL_JOB_EXECUTOR_PORT=9999
XXL_JOB_LOG_PATH=/data/applogs/xxl-job/jobhandler
XXL_JOB_LOG_RETENTION_DAYS=30

# ================================
 # 开发相关配置
 # ================================
